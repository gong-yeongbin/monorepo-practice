{
  "name": "backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "migrate": "prisma migrate dev --create-only",
    "deploy": "prisma migrate deploy",
    "generate": "prisma generate",
    "reset": "prisma migrate reset",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@aws-sdk/client-ses": "^3.1090.0",
    "@nestjs/common": "^11.1.28",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.28",
    "@nestjs/platform-express": "^11.1.28",
    "@prisma/adapter-mariadb": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dayjs": "^1.11.21",
    "ioredis": "^5.11.1",
    "mariadb": "^3.5.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.28",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.43",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.1",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.6.0",
    "jest": "^30.4.2",
    "prettier": "^3.9.4",
    "prisma": "^7.8.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.6.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "moduleNameMapper": {
      "^@common/(.*)$": "<rootDir>/common/$1",
      "^@infra/(.*)$": "<rootDir>/infra/$1",
      "^@trackers/(.*)$": "<rootDir>/trackers/$1",
      "^@tracking/(.*)$": "<rootDir>/modules/tracking/$1",
      "^@postback/(.*)$": "<rootDir>/modules/postback/$1",
      "^@user/(.*)$": "<rootDir>/modules/user/$1",
      "^@advertiser/(.*)$": "<rootDir>/modules/advertiser/$1",
      "^@advertising/(.*)$": "<rootDir>/modules/advertising/$1",
      "^@media/(.*)$": "<rootDir>/modules/media/$1",
      "^@tracker/(.*)$": "<rootDir>/modules/tracker/$1",
      "^@campaign/(.*)$": "<rootDir>/modules/campaign/$1",
      "^@config/(.*)$": "<rootDir>/modules/config/$1",
      "^@partner/(.*)$": "<rootDir>/modules/partner/$1",
      "^@dashboard/(.*)$": "<rootDir>/modules/dashboard/$1",
      "^@interceptors/(.*)$": "<rootDir>/interceptors/$1"
    },
    "transform": {
      "^.+\\.(t|j)s$": [
        "ts-jest",
        {
          "diagnostics": {
            "ignoreCodes": [
              151002
            ]
          }
        }
      ]
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s",
      "!**/*.module.ts"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
