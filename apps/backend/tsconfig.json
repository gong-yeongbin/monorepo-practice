{
  "extends": "@repo/typescript-config/nestjs.json",
  "compilerOptions": {
    "outDir": "./dist",
    "types": ["node", "jest"],
    "paths": {
      "@common/*": ["./src/common/*"],
      "@infra/*": ["./src/infra/*"],
      "@trackers/*": ["./src/trackers/*"],
      "@tracking/*": ["./src/modules/tracking/*"],
      "@postback/*": ["./src/modules/postback/*"],
      "@user/*": ["./src/modules/user/*"],
      "@auth/*": ["./src/modules/auth/*"],
      "@advertiser/*": ["./src/modules/advertiser/*"],
      "@advertising/*": ["./src/modules/advertising/*"],
      "@media/*": ["./src/modules/media/*"],
      "@tracker/*": ["./src/modules/tracker/*"],
      "@campaign/*": ["./src/modules/campaign/*"],
      "@partner/*": ["./src/modules/partner/*"],
      "@dashboard/*": ["./src/modules/dashboard/*"],
      "@interceptors/*": ["./src/interceptors/*"]
    }
  }
}
