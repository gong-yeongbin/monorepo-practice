{
	"hooks": {
		"PostToolUse": [
			{
				"matcher": "Write|Edit",
				"hooks": [
					{
						"type": "command",
						"command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/backend-endpoint-reminder.sh",
						"timeout": 10
					},
					{
						"type": "command",
						"command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/backend-lint.sh",
						"timeout": 60,
						"statusMessage": "backend ESLint 검사 중..."
					}
				]
			}
		],
		"Stop": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/backend-verify.sh",
						"timeout": 600,
						"statusMessage": "backend 테스트·타입 검증 중..."
					}
				]
			}
		]
	},
	"permissions": {
		"allow": [
			"Bash(git status *)",
			"Bash(git diff *)",
			"Bash(git log *)",
			"Bash(git show *)",
			"Bash(git blame *)",
			"Bash(git grep *)",
			"Bash(git rev-parse *)",
			"Bash(git describe *)",
			"Bash(git shortlog *)",
			"Bash(git ls-files *)",
			"Bash(git branch)",
			"Bash(git branch -a)",
			"Bash(git branch -v)",
			"Bash(git branch --list *)",
			"Bash(git branch --show-current)",
			"Bash(git remote)",
			"Bash(git remote -v)",
			"Bash(git remote get-url *)",
			"Bash(git remote show *)",
			"Bash(git config --get *)",
			"Bash(git config --list)",
			"Bash(git config -l)",
			"Bash(git submodule status *)",
			"Bash(git worktree list)",
			"Bash(git tag --list *)",
			"Bash(git tag -l *)",
			"Bash(git reflog)",
			"Bash(git reflog show *)"
		],
		"deny": [
			"Bash(git commit *)",
			"Bash(git push *)",
			"Bash(git pull *)",
			"Bash(git fetch *)",
			"Bash(git add *)",
			"Bash(git rm *)",
			"Bash(git mv *)",
			"Bash(git restore *)",
			"Bash(git reset *)",
			"Bash(git revert *)",
			"Bash(git rebase *)",
			"Bash(git merge *)",
			"Bash(git cherry-pick *)",
			"Bash(git checkout *)",
			"Bash(git switch *)",
			"Bash(git clean *)",
			"Bash(git stash *)",
			"Bash(sh *)",
			"Bash(bash *)",
			"Bash(zsh *)",
			"Bash(source *)",
			"Bash(. *)",
			"Bash(./*)",
			"Read(**/.env)",
			"Read(**/.env.*)",
			"Edit(**/.env)",
			"Edit(**/.env.*)"
		]
	}
}
